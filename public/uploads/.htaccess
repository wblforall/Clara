# Folder upload: cegah eksekusi skrip apa pun (defense-in-depth anti-RCE).
# Berlaku ke subfolder (skp, contract, signatures).
<IfModule mod_php.c>
    php_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|phps|phar|cgi|pl|py|asp|aspx|jsp|sh|htaccess)$">
    Require all denied
</FilesMatch>
Options -ExecCGI -Indexes
RemoveHandler .php .phtml .phar
RemoveType .php .phtml .phar

# Temuan pentest H2: TOLAK akses HTTP langsung ke berkas unggahan (KTP/NPWP/akta/
# surat-kuasa/TTD basah/TTD PIC). Berkas hanya boleh disajikan lewat route
# ?r=file (secure_file) yang membaca via filesystem & mewajibkan sesi/login atau
# share_token sah. Sebelumnya berkas world-readable & link permanen.
<FilesMatch "\.(jpg|jpeg|png|webp|gif|bmp|tif|tiff|pdf|svg)$">
    Require all denied
</FilesMatch>
